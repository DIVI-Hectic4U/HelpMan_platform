# ─────────────────────────────────────────────────────────────
# HelpMan Platform — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Database (Neon PostgreSQL) ────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/helpman?sslmode=require"

# ── NextAuth.js ───────────────────────────────────────────────
NEXTAUTH_SECRET="generate-a-random-32-char-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── WhatsApp Cloud API ────────────────────────────────────────
WHATSAPP_TOKEN="your-whatsapp-cloud-api-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_APP_SECRET="your-app-secret-for-webhook-verification"
WHATSAPP_VERIFY_TOKEN="your-custom-webhook-verify-token"

# ── Google Gemini AI ──────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"

# ── Server ────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
