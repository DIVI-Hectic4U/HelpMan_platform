# ─────────────────────────────────────────────────────────────
# HelpMan Platform — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Database (Neon PostgreSQL) ────────────────────────────────
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/helpman?sslmode=require"

# ── NextAuth.js ───────────────────────────────────────────────
NEXTAUTH_SECRET="your-random-32-char-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── Telegram Bot ─────────────────────────────────────────────
# Get from @BotFather on Telegram: https://t.me/BotFather
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
# Your bot username (without @)
TELEGRAM_BOT_USERNAME="your_bot_username"

# ── Web Push (VAPID) ─────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@helpman.dev"

# ── Google Gemini AI ──────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"

# ── Server ────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
